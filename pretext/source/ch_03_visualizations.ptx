      <caption>A base R dataset: Prices of over 50,000 round cut diamonds.</caption>
      <console prompt="&gt; ">
        <input>
kable(head(diamonds), caption = "A base R dataset: Prices of over 50,000 round cut diamonds.")
        </input>
        <output>
